{
  "id": "youtube-live-broadcast-checking",
  "name": "YouTube Live Broadcast Checking",
  "description": "Checks next live broadcast times and current live status for YouTube channels using YouTube Data API v3.",
  "version": "1.3.1",
  "tools": [
    {
      "name": "add_channel",
      "description": "Adds a channel to the watchlist; accepts channel ID, handle (@), or full URL",
      "input": {
        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string",
            "description": "YouTube channel ID, handle (e.g., '@chan22'), or full channel URL"
          }
        },
        "required": ["channel_id"]
      },
      "output": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    },
    {
      "name": "remove_channel",
      "description": "Removes a channel from the watchlist",
      "input": {
        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string",
            "description": "Channel ID or handle to remove"
          }
        },
        "required": ["channel_id"]
      },
      "output": {
        "type": "object",
        "properties": {
          "removed": { "type": "boolean" }
        }
      }
    },
    {
      "name": "list_channels",
      "description": "Lists all watched channels with names and timestamps",
      "input": {
        "type": "object",
        "properties": {}
      },
      "output": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "id": { "type": "string" },
            "name": { "type": "string" },
            "added_at": { "type": "string", "format": "date-time" }
          }
        }
      }
    },
    {
      "name": "get_next_broadcast",
      "description": "Fetches the earliest upcoming broadcast for a specified channel",
      "input": {
        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string",
            "description": "Channel ID or handle to check"
          }
        },
        "required": ["channel_id"]
      },
      "output": {
        "type": "object",
        "properties": {
          "channel_id": { "type": "string" },
          "channel_name": { "type": "string" },
          "video_id": { "type": "string" },
          "title": { "type": "string" },
          "scheduled_start_time": { "type": "string", "format": "date-time" },
          "thumbnail_url": { "type": "string" },
          "video_url": { "type": "string" }
        }
      }
    },
    {
      "name": "check_upcoming_broadcasts",
      "description": "Fetches upcoming broadcasts for specified channels or all watchlist; results sorted by start time",
      "input": {
        "type": "object",
        "properties": {
          "channel_ids": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Optional array of channel IDs or handles. If omitted, checks all watchlist channels."
          }
        },
        "required": []
      },
      "output": {
        "type": "array",
        "items": {
          "type": "object",
          "properties": {
            "channel_id": { "type": "string" },
            "channel_name": { "type": "string" },
            "video_id": { "type": "string" },
            "title": { "type": "string" },
            "scheduled_start_time": { "type": "string", "format": "date-time" },
            "thumbnail_url": { "type": "string" },
            "video_url": { "type": "string" }
          }
        }
      }
    },
    {
      "name": "get_live_broadcast",
      "description": "Checks if a channel is currently live streaming; returns live video details or null if not live",
      "input": {
        "type": "object",
        "properties": {
          "channel_id": {
            "type": "string",
            "description": "Channel ID or handle to check"
          }
        },
        "required": ["channel_id"]
      },
      "output": {
        "type": "object",
        "properties": {
          "channel_id": { "type": "string" },
          "video_id": { "type": "string" },
          "title": { "type": "string" },
          "description": { "type": "string" },
          "thumbnail_url": { "type": "string" },
          "video_url": { "type": "string" },
          "actual_start_time": { "type": "string", "format": "date-time" },
          "concurrent_viewers": { "type": "string" }
        }
      }
    },
    {
      "name": "check_live_status",
      "description": "[Deprecated] Use check_upcoming_broadcasts instead.",
      "input": {
        "type": "object",
        "properties": {}
      },
      "output": {
        "type": "object",
        "properties": {
          "error": { "type": "string" }
        }
      }
    }
  ],
  "runtime": "node",
  "main": "skill.js",
  "installCommand": "npm install",
  "requiredEnvVars": ["YOUTUBE_API_KEY"]
}